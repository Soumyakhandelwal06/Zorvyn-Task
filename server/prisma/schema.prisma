// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  role             Role              @default(VIEWER)
  status           Status            @default(ACTIVE)
  financialRecords FinancialRecord[]
  auditLogs        AuditLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // e.g. CREATE, UPDATE, DELETE
  resourceId String   // ID of the modified FinancialRecord
  oldData    String?  // JSON representation of old data
  newData    String?  // JSON representation of new data
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
}

model FinancialRecord {
  id          String   @id @default(uuid())
  amount      Float
  type        RecordType
  category    String
  date        DateTime @default(now())
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  ANALYST
  VIEWER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RecordType {
  INCOME
  EXPENSE
}
